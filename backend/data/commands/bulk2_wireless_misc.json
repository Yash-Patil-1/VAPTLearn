  {
    "id": "aircrack-capture",
    "tool": "aircrack-ng",
    "category": "wireless",
    "phase": 6,
    "os": [
      "linux"
    ],
    "command": "airodump-ng wlan0mon --bssid <AP_MAC> -c <channel> -w capture",
    "name": "Capture WPA Handshake",
    "description": "Captures WPA/WPA2 4-way handshake for offline cracking.",
    "arguments": {
      "--bssid": "Target AP MAC",
      "-c": "Channel",
      "-w": "Output prefix"
    },
    "expected_output": "CH  6 ][ Elapsed: 2 min ][ WPA handshake: AA:BB:CC:DD:EE:FF",
    "use_case": "Capture the authentication handshake needed to crack WiFi passwords offline.",
    "prerequisites": [
      "Monitor mode interface",
      "Target AP in range"
    ],
    "mitre_mapping": [
      "T1040"
    ],
    "mitre_tactic": "Credential Access",
    "detections": [
      "Deauth frames (if used)",
      "Unusual monitor mode activity"
    ],
    "remediation": [
      "Use WPA3",
      "Strong passwords",
      "802.1X enterprise"
    ],
    "common_mistakes": [
      "Not deauthing client to force handshake"
    ],
    "alternatives": [
      "wifite (automated)",
      "bettercap"
    ],
    "references": [
      "https://www.aircrack-ng.org"
    ],
    "tags": [
      "wifi",
      "handshake",
      "capture",
      "wpa",
      "wireless"
    ]
  },
