  {
    "id": "nmap-syn-scan",
    "tool": "nmap",
    "category": "reconnaissance",
    "phase": 1,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "nmap -sS -p- -T4 <target>",
    "name": "SYN Scan All Ports",
    "description": "Half-open SYN scan on all 65535 ports with aggressive timing.",
    "arguments": {
      "-sS": "SYN scan",
      "-p-": "All ports",
      "-T4": "Aggressive timing"
    },
    "expected_output": "PORT     STATE SERVICE\n22/tcp   open  ssh\n80/tcp   open  http\n3306/tcp open  mysql",
    "use_case": "Fast full port scan \u2014 default for most engagements.",
    "prerequisites": [
      "Root privileges"
    ],
    "mitre_mapping": [
      "T1046"
    ],
    "mitre_tactic": "Discovery",
    "detections": [
      "SYN flood detection",
      "Sequential port access patterns"
    ],
    "remediation": [
      "Host firewalls",
      "IDS/IPS",
      "Rate limiting"
    ],
    "common_mistakes": [
      "Not saving output (-oA)",
      "Scanning without root"
    ],
    "alternatives": [
      "masscan",
      "rustscan"
    ],
    "references": [
      "https://nmap.org/book/man-port-scanning-techniques.html"
    ],
    "tags": [
      "syn",
      "full-scan",
      "tcp",
      "ports"
    ]
