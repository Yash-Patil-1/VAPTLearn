  {
    "id": "nmap-decoy-scan",
    "tool": "nmap",
    "category": "reconnaissance",
    "phase": 1,
    "os": [
      "linux"
    ],
    "command": "nmap -sS -D RND:5 <target>",
    "name": "Decoy Scan (IDS Evasion)",
    "description": "Sends packets from spoofed source IPs alongside real scan to confuse IDS.",
    "arguments": {
      "-D RND:5": "Use 5 random decoy IPs",
      "-sS": "SYN scan"
    },
    "expected_output": "Nmap scan report (with decoys active)",
    "use_case": "Evade IDS by making it harder to identify the real scanner.",
    "prerequisites": [
      "Root privileges",
      "Understanding of target's IDS"
    ],
    "mitre_mapping": [
      "T1046",
      "T1205"
    ],
    "mitre_tactic": "Defense Evasion",
    "detections": [
      "Multiple source IPs scanning same target",
      "Decoy IP analysis"
    ],
    "remediation": [
      "Stateful IDS",
      "Source IP validation"
    ],
    "common_mistakes": [
      "Decoy IPs must be alive (or IDS ignores them)"
    ],
    "alternatives": [
      "nmap --source-port 53 (source port manipulation)"
    ],
    "references": [
      "https://nmap.org/book/man-bypass-firewalls-ids.html"
    ],
    "tags": [
      "decoy",
      "evasion",
      "ids-bypass",
      "stealth"
    ]
  },
  {
