    },
    "expected_output": "PORT   STATE SERVICE\n80/tcp open  http (via zombie)",
    "use_case": "Ultimate stealth \u2014 target only sees traffic from the zombie, not you.",
    "prerequisites": [
      "Zombie host with predictable IP ID sequence",
      "Root privileges"
    ],
    "mitre_mapping": [
      "T1046",
      "T1205"
    ],
    "mitre_tactic": "Defense Evasion",
    "detections": [
      "Unusual traffic from zombie host",
      "IP ID analysis"
    ],
    "remediation": [
      "Randomize IP ID sequences",
      "Monitor for idle scan patterns"
    ],
    "common_mistakes": [
      "Finding a suitable zombie (must have incremental IP IDs)"
    ],
    "alternatives": [
      "nmap -sS -D (decoy scan \u2014 easier)"
    ],
    "references": [
      "https://nmap.org/book/idlescan.html"
    ],
