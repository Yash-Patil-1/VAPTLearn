    "id": "gau-urls",
    "tool": "gau",
    "category": "reconnaissance",
    "phase": 1,
    "os": [
      "linux"
    ],
    "command": "gau <domain> | grep -E '\\.(php|asp|jsp|js)' | sort -u",
    "name": "Get All URLs (Historical)",
    "description": "Fetches known URLs from Wayback Machine, Common Crawl, and AlienVault OTX.",
    "arguments": {
      "<domain>": "Target domain",
      "grep": "Filter interesting extensions",
      "sort -u": "Deduplicate"
    },
    "expected_output": "http://target.com/admin/config.php\nhttp://target.com/api/v1/users.js",
    "use_case": "Find historical endpoints, parameters, and forgotten files from web archives.",
    "prerequisites": [
      "Target domain",
      "Internet access"
    ],
    "mitre_mapping": [
      "T1596.003"
    ],
    "mitre_tactic": "Reconnaissance",
    "detections": [
      "Passive \u2014 queries archives, not target"
    ],
    "remediation": [
      "Remove old endpoints",
      "Implement access controls"
    ],
    "common_mistakes": [
      "Not checking if URLs are still live (pipe to httpx)"
    ],
    "alternatives": [
      "waybackurls",
      "katana (active crawler)"
    ],
    "references": [
      "https://github.com/lc/gau"
    ],
    "tags": [
      "urls",
      "historical",
      "archive",
      "passive",
      "endpoints"
    ]
