[
  {
    "id": "openvas-scan",
    "tool": "openvas",
    "category": "vulnerability_assessment",
    "phase": 3,
    "os": [
      "linux"
    ],
    "command": "gvm-cli --gmp-username admin --gmp-password pass socket --socketpath /run/gvmd/gvmd.sock --xml '<create_task>...'",
    "name": "OpenVAS Vulnerability Scan",
    "description": "Full vulnerability assessment using OpenVAS/Greenbone \u2014 enterprise-grade scanner.",
    "arguments": {
      "gvm-cli": "GVM command line",
      "create_task": "Create scan task"
    },
    "expected_output": "High: CVE-2021-44228 (Log4Shell) - CVSS 10.0\nMedium: CVE-2023-1234 - CVSS 6.5",
    "use_case": "Comprehensive vulnerability scanning with detailed CVE reporting.",
    "prerequisites": [
      "OpenVAS/GVM installed",
      "Target accessible"
    ],
    "mitre_mapping": [
      "T1595"
    ],
    "mitre_tactic": "Reconnaissance",
    "detections": [
      "Vulnerability scan traffic patterns",
      "Multiple exploit probes"
    ],
    "remediation": [
      "Patch identified vulnerabilities",
      "Prioritize by CVSS"
    ],
    "common_mistakes": [
      "Not updating NVT feeds before scanning"
    ],
    "alternatives": [
      "Nessus",
      "Qualys",
      "nuclei"
    ],
    "references": [
      "https://www.greenbone.net"
    ],
    "tags": [
      "openvas",
      "vulnerability",
      "scanner",
      "enterprise",
      "cve"
    ]
  },
  {
    "id": "nmap-vulners-scan",
    "tool": "nmap",
    "category": "vulnerability_assessment",
    "phase": 3,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "nmap -sV --script vulners --script-args mincvss=7.0 -p <ports> <target>",
    "name": "CVE Lookup (High Severity)",
    "description": "Checks service versions against Vulners database \u2014 filters for CVSS 7.0+.",
    "arguments": {
      "--script vulners": "Vulners CVE database",
      "mincvss=7.0": "Only show high/critical"
    },
    "expected_output": "| vulners:\n|   CVE-2021-44228  10.0\n|   CVE-2023-22515  9.8",
    "use_case": "Quick high-severity CVE check without a full vulnerability scanner.",
    "prerequisites": [
      "Service versions detected (-sV)"
    ],
    "mitre_mapping": [
      "T1595"
    ],
    "mitre_tactic": "Reconnaissance",
    "detections": [
      "Version probing"
    ],
    "remediation": [
      "Patch critical CVEs immediately"
    ],
    "common_mistakes": [
      "Not running -sV first"
    ],
    "alternatives": [
      "nuclei -severity critical,high",
      "searchsploit"
    ],
    "references": [
      "https://github.com/vulnersCom/nmap-vulners"
    ],
    "tags": [
      "cve",
      "high-severity",
      "vulners",
      "quick-check"
    ]
  },
  {
