[
  {
    "id": "nmap-script-banner",
    "tool": "nmap",
    "category": "reconnaissance",
    "phase": 1,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "nmap --script banner -p 1-10000 <target>",
    "name": "Banner Grabbing (All Ports)",
    "description": "Grabs service banners from all open ports \u2014 reveals software versions and custom messages.",
    "arguments": {
      "--script banner": "Grab banners",
      "-p 1-10000": "First 10000 ports"
    },
    "expected_output": "| banner: SSH-2.0-OpenSSH_8.9p1\n| banner: 220 ProFTPD 1.3.5",
    "use_case": "Identify services by their banners \u2014 sometimes reveals internal hostnames or version info.",
    "prerequisites": [
      "Open ports"
    ],
    "mitre_mapping": [
      "T1046"
    ],
    "mitre_tactic": "Discovery",
    "detections": [
      "Banner grab connections"
    ],
    "remediation": [
      "Customize banners to hide version info"
    ],
    "common_mistakes": [
      "Not checking high ports"
    ],
    "alternatives": [
      "nc -v <target> <port>",
      "telnet"
    ],
    "references": [
      "https://nmap.org/nsedoc/scripts/banner.html"
    ],
    "tags": [
      "banner",
      "version",
      "identification",
      "service"
    ]
