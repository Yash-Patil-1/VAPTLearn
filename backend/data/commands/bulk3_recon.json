    ],
    "command": "nmap -sA -p 80,443 <target>",
    "name": "ACK Scan (Firewall Detection)",
    "description": "Determines if ports are filtered by a firewall \u2014 ACK packets bypass stateless firewalls.",
    "arguments": {
      "-sA": "ACK scan (detects filtering)"
    },
    "expected_output": "PORT   STATE      SERVICE\n80/tcp unfiltered http\n443/tcp filtered  https",
    "use_case": "Determine which ports are filtered by firewalls vs actually closed.",
    "prerequisites": [
      "Root privileges"
    ],
    "mitre_mapping": [
      "T1046"
    ],
    "mitre_tactic": "Discovery",
    "detections": [
      "ACK packets without prior SYN"
    ],
    "remediation": [
      "Stateful firewalls",
      "IDS"
    ],
    "common_mistakes": [
      "Confusing 'unfiltered' with 'open'"
    ],
    "alternatives": [
      "nmap -sW (Window scan)"
    ],
    "references": [
      "https://nmap.org/book/man-port-scanning-techniques.html"
    ],
    "tags": [
      "firewall",
      "detection",
      "ack",
      "filtering"
    ]
