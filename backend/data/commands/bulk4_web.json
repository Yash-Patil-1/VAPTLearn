[
  {
    "id": "nuclei-takeover",
    "tool": "nuclei",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "nuclei -u http://<target> -t takeovers/",
    "name": "Subdomain Takeover Check",
    "description": "Detects dangling DNS records pointing to unclaimed services (S3, Heroku, GitHub Pages, etc.).",
    "arguments": {
      "-t takeovers/": "Takeover detection templates"
    },
    "expected_output": "[takeover] [high] http://old.target.com \u2192 GitHub Pages (unclaimed)",
    "use_case": "Find subdomains pointing to decommissioned services that can be claimed by attackers.",
    "prerequisites": [
      "Subdomain list"
    ],
    "mitre_mapping": [
      "T1584"
    ],
    "mitre_tactic": "Resource Development",
    "detections": [
      "DNS changes",
      "New content on previously dead subdomains"
    ],
    "remediation": [
      "Remove stale DNS records",
      "Monitor for dangling CNAMEs"
    ],
    "common_mistakes": [
      "Not checking all subdomains"
    ],
    "alternatives": [
      "subjack",
      "can-i-take-over-xyz"
    ],
    "references": [
      "https://github.com/projectdiscovery/nuclei-templates"
    ],
    "tags": [
      "takeover",
      "subdomain",
      "dangling",
      "dns"
    ]
  },
