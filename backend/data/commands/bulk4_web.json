  {
    "id": "cors-misconfiguration",
    "tool": "curl",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "curl -s -I -H 'Origin: https://evil.com' http://<target>/api/ | grep -i access-control",
    "name": "CORS Misconfiguration Test",
    "description": "Tests if the server reflects arbitrary origins in CORS headers \u2014 allows cross-origin data theft.",
    "arguments": {
      "-H 'Origin: https://evil.com'": "Fake origin",
      "grep access-control": "Check CORS headers"
    },
    "expected_output": "Access-Control-Allow-Origin: https://evil.com\nAccess-Control-Allow-Credentials: true",
    "use_case": "If server reflects any origin with credentials, attackers can steal user data cross-origin.",
    "prerequisites": [
      "API endpoint"
    ],
    "mitre_mapping": [
      "T1189"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "Unusual Origin headers",
      "Cross-origin requests from unknown domains"
    ],
    "remediation": [
      "Whitelist specific origins",
      "Never reflect arbitrary origins with credentials"
    ],
    "common_mistakes": [
      "Not testing with credentials flag"
    ],
    "alternatives": [
      "burp scanner",
      "corsy"
    ],
    "references": [
      "https://portswigger.net/web-security/cors"
    ],
    "tags": [
      "cors",
      "misconfiguration",
      "cross-origin",
      "api"
    ]
  },
  {
    "id": "crlf-injection",
    "tool": "curl",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "curl -v 'http://<target>/redirect?url=http://target.com%0d%0aSet-Cookie:hacked=true'",
    "name": "CRLF Injection Test",
    "description": "Tests for HTTP header injection via CRLF characters (%0d%0a) in parameters.",
    "arguments": {
      "%0d%0a": "Carriage Return + Line Feed (header separator)"
    },
    "expected_output": "< HTTP/1.1 302 Found\n< Location: http://target.com\n< Set-Cookie: hacked=true",
    "use_case": "Inject arbitrary HTTP headers \u2014 can set cookies, redirect, or enable XSS.",
    "prerequisites": [
      "Parameter reflected in HTTP headers"
    ],
    "mitre_mapping": [
      "T1190"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "CRLF characters in request parameters",
      "Unusual Set-Cookie headers"
    ],
    "remediation": [
      "Sanitize CRLF from all input",
      "Don't reflect user input in headers"
    ],
    "common_mistakes": [
      "Not URL-encoding properly"
    ],
    "alternatives": [
      "crlfuzz",
      "burp scanner"
    ],
    "references": [
      "https://owasp.org/www-community/vulnerabilities/CRLF_Injection"
    ],
    "tags": [
      "crlf",
      "header-injection",
      "cookie",
      "redirect"
    ]
  },
  {
    "id": "open-redirect",
    "tool": "curl",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "curl -v 'http://<target>/login?next=https://evil.com'",
    "name": "Open Redirect Test",
    "description": "Tests if redirect parameters accept external URLs \u2014 used for phishing.",
    "arguments": {
      "next=https://evil.com": "External redirect URL"
    },
    "expected_output": "< HTTP/1.1 302 Found\n< Location: https://evil.com",
    "use_case": "Open redirects enable convincing phishing \u2014 victim sees legitimate domain in link.",
    "prerequisites": [
      "URL parameter controlling redirects"
    ],
    "mitre_mapping": [
      "T1566"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "Redirects to external domains",
      "Unusual redirect patterns"
    ],
    "remediation": [
      "Whitelist redirect destinations",
      "Validate redirect URLs server-side"
    ],
    "common_mistakes": [
      "Not trying bypass techniques (//evil.com, /\\evil.com)"
    ],
    "alternatives": [
      "openredirex",
      "burp scanner"
    ],
    "references": [
      "https://portswigger.net/web-security/open-redirect"
    ],
    "tags": [
      "redirect",
      "phishing",
      "bypass",
      "url"
    ]
