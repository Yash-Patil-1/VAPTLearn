  {
    "id": "race-condition",
    "tool": "turbo-intruder",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "# Burp Turbo Intruder: Send 20 requests simultaneously\n# Target: POST /api/transfer (amount=1000)\n# Goal: Transfer executes multiple times before balance check",
    "name": "Race Condition Exploitation",
    "description": "Exploits time-of-check-to-time-of-use (TOCTOU) vulnerabilities by sending concurrent requests.",
    "arguments": {
      "Turbo Intruder": "Burp extension for parallel requests"
    },
    "expected_output": "# Result: Balance deducted once, but transfer executed 5 times",
    "use_case": "Exploit race conditions in financial transactions, coupon redemption, or vote systems.",
    "prerequisites": [
      "Endpoint with non-atomic operations",
      "Burp Turbo Intruder"
    ],
    "mitre_mapping": [
      "T1190"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "Multiple identical requests in milliseconds",
      "Inconsistent database state"
    ],
    "remediation": [
      "Use database transactions",
      "Implement idempotency keys",
      "Mutex/locking"
    ],
    "common_mistakes": [
      "Not sending enough concurrent requests"
    ],
    "alternatives": [
      "racepwn",
      "turbo intruder"
    ],
    "references": [
      "https://portswigger.net/web-security/race-conditions"
    ],
    "tags": [
      "race-condition",
      "toctou",
      "concurrent",
      "financial"
    ]
  }
