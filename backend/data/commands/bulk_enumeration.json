[
  {
    "id": "nmap-smb-shares",
    "tool": "nmap",
    "category": "enumeration",
    "phase": 2,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "nmap --script smb-enum-shares,smb-ls -p 445 <target>",
    "name": "SMB Share Listing with Contents",
    "description": "Enumerates SMB shares AND lists files in accessible shares.",
    "arguments": {
      "smb-enum-shares": "List shares",
      "smb-ls": "List files in shares"
    },
    "expected_output": "| ADMIN$ - Remote Admin (NO ACCESS)\n| SharedDocs - (READ)\n|   backup.zip\n|   passwords.xlsx",
    "use_case": "Find readable shares and identify sensitive files without manual connection.",
    "prerequisites": [
      "SMB port 445 open"
    ],
    "mitre_mapping": [
      "T1135",
      "T1039"
    ],
    "mitre_tactic": "Discovery",
    "detections": [
      "SMB enumeration in audit logs"
    ],
    "remediation": [
      "Restrict share permissions",
      "Remove sensitive files from shares"
    ],
    "common_mistakes": [
      "Not listing file contents"
    ],
    "alternatives": [
      "smbclient",
      "smbmap -R"
    ],
    "references": [
      "https://nmap.org/nsedoc/scripts/smb-enum-shares.html"
    ],
    "tags": [
      "smb",
      "shares",
      "files",
      "enumeration"
    ]
  },
