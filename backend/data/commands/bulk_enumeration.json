    "prerequisites": [
      "Finger port 79 open"
    ],
    "mitre_mapping": [
      "T1087"
    ],
    "mitre_tactic": "Discovery",
    "detections": [
      "Finger queries in service logs"
    ],
    "remediation": [
      "Disable finger service",
      "Block port 79"
    ],
    "common_mistakes": [
      "Not checking if finger is running (rare service)"
    ],
    "alternatives": [
      "nmap --script finger",
      "rusers"
    ],
    "references": [
      "https://linux.die.net/man/1/finger"
