    "tool": "mysql",
    "category": "enumeration",
    "phase": 2,
    "os": [
      "linux"
    ],
    "command": "mysql -h <target> -u root -p'' -e 'SELECT user,host FROM mysql.user;'",
    "name": "MySQL Enumeration",
    "description": "Connects to MySQL and enumerates users \u2014 tests for empty root password.",
    "arguments": {
      "-h": "Target host",
      "-u root": "Username",
      "-p''": "Empty password",
      "-e": "Execute query"
    },
    "expected_output": "user    host\nroot    localhost\nroot    %\nadmin   %",
    "use_case": "Check for MySQL with weak/empty credentials \u2014 common in development environments.",
    "prerequisites": [
      "MySQL port 3306 open",
      "Weak or empty credentials"
    ],
    "mitre_mapping": [
      "T1078"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "Failed MySQL auth attempts",
      "Successful auth from unusual IP"
    ],
    "remediation": [
      "Set strong root password",
      "Restrict remote root access",
      "Use mysql_secure_installation"
    ],
    "common_mistakes": [
      "Not trying common passwords",
      "Missing UDF for RCE"
    ],
    "alternatives": [
      "nmap --script mysql-enum",
      "hydra mysql"
    ],
    "references": [
      "https://book.hacktricks.wiki/en/network-services-pentesting/pentesting-mysql"
