      "Ident port 113 open (rare)"
    ],
    "mitre_mapping": [
      "T1087"
    ],
    "mitre_tactic": "Discovery",
    "detections": [
      "Ident queries in logs"
    ],
    "remediation": [
      "Disable ident service"
    ],
    "common_mistakes": [
