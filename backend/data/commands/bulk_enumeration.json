  {
    "id": "redis-enum",
    "tool": "redis-cli",
    "category": "enumeration",
    "phase": 2,
    "os": [
      "linux"
    ],
    "command": "redis-cli -h <target> INFO",
    "name": "Redis Enumeration",
    "description": "Connects to Redis and retrieves server information \u2014 often unauthenticated.",
    "arguments": {
      "-h": "Target host",
      "INFO": "Get server information"
    },
    "expected_output": "# Server\nredis_version:6.2.6\nos:Linux 5.4.0\n# Keyspace\ndb0:keys=1523",
    "use_case": "Check for unauthenticated Redis \u2014 can lead to RCE via config set or module loading.",
    "prerequisites": [
      "Redis port 6379 open",
      "No authentication (common misconfiguration)"
    ],
    "mitre_mapping": [
      "T1190"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "Redis connection from unauthorized IP"
    ],
    "remediation": [
      "Require authentication (requirepass)",
      "Bind to localhost only",
      "Disable dangerous commands"
    ],
    "common_mistakes": [
      "Not trying to write files (config set dir/dbfilename)"
    ],
    "alternatives": [
      "nmap --script redis-info"
    ],
    "references": [
      "https://book.hacktricks.wiki/en/network-services-pentesting/6379-pentesting-redis"
    ],
    "tags": [
      "redis",
      "database",
      "unauthenticated",
      "rce"
    ]
  },
