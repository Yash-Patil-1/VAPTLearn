    ],
    "command": "ldapdomaindump -u '<domain>\\<user>' -p '<pass>' <dc_ip>",
    "name": "LDAP Domain Dump",
    "description": "Dumps all AD objects (users, groups, computers, policies) via LDAP into HTML/JSON reports.",
    "arguments": {
      "-u": "Domain\\username",
      "-p": "Password",
      "<dc_ip>": "Domain controller"
    },
    "expected_output": "[*] Dumping domain info...\n[+] domain_users.html\n[+] domain_groups.html\n[+] domain_computers.html",
    "use_case": "Get a complete picture of the AD environment \u2014 users, groups, computers, GPOs.",
