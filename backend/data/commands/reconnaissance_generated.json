[
  {
    "id": "nmap-smb-vuln-scripts",
    "tool": "nmap",
    "category": "reconnaissance",
    "phase": 1,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "nmap --script smb-vuln* -p 445 <target>",
    "name": "SMB Vulnerability Scripts",
    "description": "Runs all SMB vulnerability detection scripts including EternalBlue (MS17-010), MS08-067, and other critical SMB flaws.",
    "arguments": {
      "--script smb-vuln*": "All SMB vuln scripts",
      "-p 445": "SMB port"
    },
    "expected_output": "| smb-vuln-ms17-010:\n|   VULNERABLE:\n|   Remote Code Execution in SMBv1",
    "use_case": "Check for critical SMB vulnerabilities that allow RCE.",
    "prerequisites": [
      "SMB port 445 open"
    ],
    "mitre_mapping": [
      "T1190",
      "T1210"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "IDS signatures for SMB exploit probes",
      "SMB audit logs"
    ],
    "remediation": [
      "Disable SMBv1",
      "Apply MS17-010 patch",
      "Block 445 at perimeter"
    ],
    "common_mistakes": [
      "Not checking if SMBv1 is enabled"
    ],
    "alternatives": [
      "netexec smb <target> -M ms17-010"
    ],
    "references": [
      "https://nmap.org/nsedoc/scripts/smb-vuln-ms17-010.html"
    ],
    "tags": [
      "smb",
      "vulnerability",
      "eternalblue",
      "nse"
    ]
  },
