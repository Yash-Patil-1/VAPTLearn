    ],
    "command": "nmap --script ftp-anon -p 21 <target>",
    "name": "FTP Anonymous Login Check",
    "description": "Checks if FTP server allows anonymous login \u2014 a common misconfiguration.",
    "arguments": {
      "--script ftp-anon": "Check anonymous FTP",
      "-p 21": "FTP port"
    },
    "expected_output": "| ftp-anon: Anonymous FTP login allowed\n|   drwxr-xr-x  2 ftp ftp  4096 Jan 01 backup/",
    "use_case": "Identify FTP servers allowing anonymous access \u2014 may contain sensitive files.",
    "prerequisites": [
      "FTP port 21 open"
    ],
    "mitre_mapping": [
      "T1078"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "FTP login events",
      "Anonymous access logs"
    ],
    "remediation": [
      "Disable anonymous FTP",
      "Restrict FTP access",
      "Use SFTP instead"
    ],
    "common_mistakes": [
      "Not checking file contents after finding anon access"
    ],
    "alternatives": [
      "ftp <target> (manual)",
      "netexec ftp <target> -u anonymous -p ''"
    ],
    "references": [
      "https://nmap.org/nsedoc/scripts/ftp-anon.html"
    ],
    "tags": [
      "ftp",
      "anonymous",
