      "crt.sh": "CT log search engine",
      "%25": "Wildcard (URL-encoded %)",
      "jq": "Parse JSON output"
    },
    "expected_output": "www.target.com\napi.target.com\nstaging.target.com\ninternal.target.com",
    "use_case": "Discover subdomains from SSL certificate registrations \u2014 often reveals internal/staging hosts.",
    "prerequisites": [
      "Target domain",
      "curl + jq installed"
    ],
    "mitre_mapping": [
      "T1596.002"
    ],
    "mitre_tactic": "Reconnaissance",
    "detections": [
      "Completely passive \u2014 no target interaction"
    ],
    "remediation": [
      "Monitor CT logs for unauthorized certificates",
      "Remove old certificates"
    ],
    "common_mistakes": [
      "Not combining with other subdomain sources"
    ],
    "alternatives": [
