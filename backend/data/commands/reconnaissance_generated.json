    ],
    "command": "cat subdomains.txt | httpx -status-code -title -tech-detect -o live.txt",
    "name": "HTTP Probing & Tech Detection",
    "description": "Probes a list of subdomains to find live web servers, their status codes, titles, and technologies.",
