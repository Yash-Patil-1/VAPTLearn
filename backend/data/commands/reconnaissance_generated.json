      "-status-code": "Show HTTP status",
      "title": "Show page title",
      "-tech-detect": "Detect technologies",
      "-o": "Output file"
    },
    "expected_output": "https://api.target.com [200] [API Gateway] [Nginx]\nhttps://dev.target.com [403] [Forbidden] [Apache]",
