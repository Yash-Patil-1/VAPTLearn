[
  {
    "id": "ffuf-subdomain",
    "tool": "ffuf",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "ffuf -u http://<target> -H 'Host: FUZZ.target.com' -w subdomains.txt -fs <size>",
    "name": "Subdomain via Host Header",
    "description": "Discovers virtual hosts by fuzzing Host header.",
    "arguments": {
      "-H": "Custom Host header",
      "-fs": "Filter default size"
    },
    "expected_output": "dev [200, 4521]\nstaging [200, 3892]",
    "use_case": "Find hidden vhosts on same IP.",
    "prerequisites": [
      "Target IP",
      "Default response size known"
    ],
    "mitre_mapping": [
      "T1595"
    ],
    "mitre_tactic": "Reconnaissance",
    "detections": [
      "Unusual Host headers in logs"
    ],
    "remediation": [
      "Reject unknown Host headers"
    ],
    "common_mistakes": [
      "Not filtering default response"
    ],
    "alternatives": [
      "gobuster vhost",
      "wfuzz"
    ],
    "references": [
      "https://github.com/ffuf/ffuf"
    ],
    "tags": [
      "vhost",
      "subdomain",
      "host-header",
      "fuzzing"
    ]
  },
