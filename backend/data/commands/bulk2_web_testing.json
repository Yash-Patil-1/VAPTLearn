      "Use parameterized queries"
    ],
    "common_mistakes": [
      "Not trying multiple tamper combinations"
    ],
    "alternatives": [
      "manual encoding",
      "custom payloads"
    ],
    "references": [
      "https://sqlmap.org"
    ],
    "tags": [
      "sqli",
      "waf-bypass",
      "tamper",
      "evasion"
