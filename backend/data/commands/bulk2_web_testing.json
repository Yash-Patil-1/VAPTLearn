      "Confirmed SQL injection",
      "DBA privileges or FILE privilege"
    ],
    "mitre_mapping": [
      "T1190",
      "T1059"
    ],
    "mitre_tactic": "Execution",
    "detections": [
      "Unusual file writes by DB process",
      "Command execution from DB user"
    ],
    "remediation": [
      "Least privilege for DB accounts",
      "Disable FILE privilege"
    ],
    "common_mistakes": [
      "DB user doesn't have FILE privilege"
    ],
    "alternatives": [
      "manual INTO OUTFILE",
      "xp_cmdshell (MSSQL)"
    ],
    "references": [
      "https://sqlmap.org"
    ],
    "tags": [
      "sqli",
      "rce",
      "os-shell",
      "command-execution"
    ]
