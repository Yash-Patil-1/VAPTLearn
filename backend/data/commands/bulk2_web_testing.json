    "expected_output": "root:x:0:0:root:/root:/bin/bash\nwww-data:x:33:33:...",
    "use_case": "Read sensitive files from the server \u2014 /etc/passwd, config files, source code.",
    "prerequisites": [
      "File inclusion parameter",
      "Linux target"
    ],
    "mitre_mapping": [
      "T1005"
    ],
    "mitre_tactic": "Collection",
    "detections": [
      "Path traversal patterns in logs (../)",
      "Access to sensitive file paths"
    ],
    "remediation": [
      "Input validation",
      "Chroot/jail",
      "Disable allow_url_include"
    ],
    "common_mistakes": [
      "Not trying enough ../ levels",
      "Missing null byte (%00) for older PHP"
    ],
    "alternatives": [
      "dotdotpwn",
      "burp intruder with traversal list"
    ],
    "references": [
      "https://portswigger.net/web-security/file-path-traversal"
