    "mitre_tactic": "Execution",
    "detections": [
      "Template syntax in parameters",
      "Unusual server errors"
    ],
    "remediation": [
      "Sandbox template engines",
      "Don't pass user input to templates",
      "Use logic-less templates"
    ],
    "common_mistakes": [
