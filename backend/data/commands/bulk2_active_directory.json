  {
    "id": "impacket-smbexec",
    "tool": "impacket",
    "category": "active_directory",
    "phase": 6,
    "os": [
      "linux"
    ],
    "command": "impacket-smbexec <domain>/<user>:<pass>@<target>",
    "name": "SMB Exec (Stealthier)",
    "description": "Executes commands via SMB without creating a service \u2014 stealthier than PsExec.",
    "arguments": {
      "<domain>/<user>:<pass>@<target>": "Credentials and target"
    },
    "expected_output": "C:\\Windows\\system32>whoami\ncorp\\admin",
    "use_case": "Stealthier than PsExec \u2014 doesn't create a service binary on disk.",
    "prerequisites": [
      "Admin credentials",
      "SMB access"
    ],
    "mitre_mapping": [
      "T1021.002"
    ],
    "mitre_tactic": "Lateral Movement",
    "detections": [
      "SMB file operations",
      "Command execution patterns"
    ],
    "remediation": [
      "Monitor SMB activity",
      "Restrict admin shares"
    ],
    "common_mistakes": [
      "Slower than PsExec"
    ],
    "alternatives": [
      "impacket-psexec",
      "impacket-wmiexec"
    ],
    "references": [
      "https://github.com/fortra/impacket"
    ],
    "tags": [
      "smb",
