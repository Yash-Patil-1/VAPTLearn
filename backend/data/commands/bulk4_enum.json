[
  {
    "id": "ftp-bounce",
    "tool": "nmap",
    "category": "enumeration",
    "phase": 2,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "nmap -b <ftp_server> <target>",
    "name": "FTP Bounce Scan",
    "description": "Uses an FTP server to scan another host \u2014 the FTP server acts as a proxy.",
    "arguments": {
      "-b": "FTP bounce scan via specified server"
    },
    "expected_output": "PORT   STATE SERVICE\n80/tcp open  http (via FTP bounce)",
    "use_case": "Scan hosts behind firewalls using a misconfigured FTP server as a relay.",
    "prerequisites": [
      "FTP server allowing PORT command to other hosts"
    ],
    "mitre_mapping": [
      "T1090"
    ],
    "mitre_tactic": "Defense Evasion",
    "detections": [
      "Unusual FTP PORT commands",
      "FTP data connections to third parties"
    ],
    "remediation": [
      "Disable FTP bounce (modern servers do by default)"
    ],
    "common_mistakes": [
      "Very rare \u2014 most FTP servers patched"
    ],
    "alternatives": [
      "nmap -sS (direct scan)"
    ],
    "references": [
      "https://nmap.org/book/man-port-scanning-techniques.html"
    ],
    "tags": [
      "ftp",
      "bounce",
      "proxy",
      "scan",
      "evasion"
    ]
  },
