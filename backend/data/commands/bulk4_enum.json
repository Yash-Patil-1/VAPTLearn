    ],
    "command": "ike-scan <target>",
    "name": "IKE/VPN Gateway Detection",
    "description": "Detects IPSec VPN gateways and identifies their configuration.",
    "arguments": {
      "<target>": "Target IP"
    },
    "expected_output": "192.168.1.1\tMain Mode Handshake returned\n\tAuth=PSK, Enc=3DES, Hash=SHA1",
    "use_case": "Discover VPN gateways and their encryption settings \u2014 weak configs may be exploitable.",
    "prerequisites": [
      "UDP port 500 open"
    ],
    "mitre_mapping": [
      "T1046"
    ],
    "mitre_tactic": "Discovery",
    "detections": [
      "IKE probes on port 500"
    ],
    "remediation": [
      "Use strong VPN configurations",
      "Restrict VPN access"
    ],
    "common_mistakes": [
      "Not trying aggressive mode (ike-scan -A)"
    ],
    "alternatives": [
      "nmap --script ike-version"
    ],
    "references": [
      "https://github.com/royhills/ike-scan"
    ],
    "tags": [
      "vpn",
      "ipsec",
      "ike",
      "gateway",
      "detection"
    ]
