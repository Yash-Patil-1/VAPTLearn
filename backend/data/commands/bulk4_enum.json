  {
    "id": "smtp-commands",
    "tool": "nmap",
    "category": "enumeration",
    "phase": 2,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "nmap --script smtp-commands -p 25 <target>",
    "name": "SMTP Command Enumeration",
    "description": "Discovers supported SMTP commands \u2014 VRFY and EXPN enable user enumeration.",
    "arguments": {
      "--script smtp-commands": "Check supported commands"
    },
    "expected_output": "| smtp-commands: mail.target.com\n|   VRFY, EXPN, ETRN, SIZE, HELP",
    "use_case": "Identify if SMTP server supports VRFY/EXPN for user enumeration.",
    "prerequisites": [
      "SMTP port 25 open"
    ],
    "mitre_mapping": [
      "T1589"
    ],
    "mitre_tactic": "Reconnaissance",
    "detections": [
      "SMTP command probing"
    ],
    "remediation": [
      "Disable VRFY and EXPN"
    ],
    "common_mistakes": [
      "Not following up with user enumeration"
    ],
    "alternatives": [
      "smtp-user-enum",
      "swaks"
    ],
    "references": [
      "https://nmap.org/nsedoc/scripts/smtp-commands.html"
    ],
    "tags": [
      "smtp",
      "commands",
      "vrfy",
      "expn",
      "mail"
    ]
