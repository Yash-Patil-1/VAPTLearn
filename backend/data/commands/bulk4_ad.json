    "description": "Exploits IPv6 to become the DNS server, then relays authentication for delegation access.",
    "arguments": {
      "mitm6": "IPv6 DNS poisoning",
      "ntlmrelayx -6": "Relay IPv6 auth",
      "--delegate-access": "Create computer with delegation"
    },
    "expected_output": "[*] IPv6 DNS takeover active\n[+] Relayed auth: CORP\\PC01$\n[+] Created computer with delegation rights",
    "use_case": "Combine IPv6 poisoning with NTLM relay for domain escalation \u2014 very effective in modern AD.",
    "prerequisites": [
      "IPv6 enabled (default)",
      "LDAPS on DC"
    ],
    "mitre_mapping": [
      "T1557",
      "T1187"
    ],
    "mitre_tactic": "Credential Access",
    "detections": [
      "IPv6 DNS responses from non-DC",
      "New computer objects",
      "Delegation changes"
    ],
    "remediation": [
      "Disable IPv6 if not needed",
      "Enable LDAP signing",
      "Monitor computer object creation"
    ],
    "common_mistakes": [
      "IPv6 disabled",
      "LDAP signing enforced"
    ],
    "alternatives": [
      "Responder (IPv4 only)",
      "PetitPotam"
    ],
    "references": [
      "https://github.com/dirkjanm/mitm6"
    ],
    "tags": [
      "ipv6",
      "dns",
      "relay",
      "delegation",
      "takeover"
    ]
