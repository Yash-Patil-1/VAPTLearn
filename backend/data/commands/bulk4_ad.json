[
  {
    "id": "netexec-spider",
    "tool": "netexec",
    "category": "active_directory",
    "phase": 6,
    "os": [
      "linux"
    ],
    "command": "netexec smb <target> -u user -p pass --spider C$ --regex '(password|credential|secret)'",
    "name": "SMB Spider (File Search)",
    "description": "Recursively searches SMB shares for files matching regex patterns.",
    "arguments": {
      "--spider C$": "Crawl C$ share",
      "--regex": "Search pattern"
    },
    "expected_output": "[+] //target/C$/Users/admin/Desktop/passwords.txt\n[+] //target/C$/Scripts/deploy_creds.ps1",
    "use_case": "Find sensitive files (passwords, credentials, configs) across network shares.",
    "prerequisites": [
      "Admin access to shares"
    ],
    "mitre_mapping": [
      "T1039",
      "T1552"
    ],
    "mitre_tactic": "Collection",
    "detections": [
      "Mass file access on shares",
      "Regex-based file searching"
    ],
    "remediation": [
      "Remove sensitive files from shares",
      "DLP"
    ],
    "common_mistakes": [
      "Not trying other shares (SYSVOL, NETLOGON)"
    ],
    "alternatives": [
      "snaffler",
      "manspider"
    ],
    "references": [
      "https://github.com/Pennyw0rth/NetExec"
    ],
    "tags": [
      "spider",
      "file-search",
      "credentials",
      "shares"
    ]
  },
