      "Payload position": "Mark field with \u00a7\u00a7",
      "Wordlist": "Password list"
    },
    "expected_output": "Request 1: admin/password123 \u2192 302 (redirect = success)\nRequest 2: admin/admin \u2192 200 (login page = failed)",
    "use_case": "Brute-force web login forms when you have a username but not the password.",
    "prerequisites": [
      "Burp Suite running",
      "Intercepted login request",
      "Username known"
    ],
    "mitre_mapping": [
      "T1110.001"
    ],
    "mitre_tactic": "Credential Access",
    "detections": [
      "Multiple failed login attempts",
      "Account lockout triggers"
    ],
    "remediation": [
      "Implement account lockout",
      "Rate limiting",
      "CAPTCHA after failures",
      "MFA"
    ],
    "common_mistakes": [
