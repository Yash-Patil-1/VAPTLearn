[
  {
    "id": "ffuf-param-fuzz",
    "tool": "ffuf",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "ffuf -u 'http://<target>/page?FUZZ=value' -w /usr/share/seclists/Discovery/Web-Content/burp-parameter-names.txt -fs <default_size>",
    "name": "Parameter Discovery",
    "description": "Discovers hidden GET parameters by fuzzing parameter names.",
    "arguments": {
      "-u": "URL with FUZZ keyword in param name",
      "-w": "Parameter name wordlist",
      "-fs": "Filter by response size"
    },
    "expected_output": "id                      [Status: 200, Size: 4521]\ndebug                   [Status: 200, Size: 8923]\nadmin                   [Status: 200, Size: 1200]",
    "use_case": "Find hidden parameters that may reveal debug info, admin functions, or injection points.",
    "prerequisites": [
      "Target URL",
      "SecLists wordlist"
    ],
    "mitre_mapping": [
      "T1190"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "Unusual parameter names in WAF logs",
      "High request volume"
    ],
    "remediation": [
      "Input validation on all parameters",
      "Remove debug parameters in production"
    ],
    "common_mistakes": [
      "Not filtering default response size",
      "Missing POST parameters"
    ],
    "alternatives": [
      "arjun (dedicated param finder)",
      "paramspider"
    ],
    "references": [
      "https://github.com/ffuf/ffuf"
    ],
    "tags": [
      "parameter",
      "fuzzing",
      "hidden",
      "web",
      "discovery"
    ]
  },
  {
    "id": "ffuf-post-fuzz",
    "tool": "ffuf",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "ffuf -u http://<target>/login -X POST -d 'username=admin&FUZZ=test' -w wordlist.txt -fs <size>",
    "name": "POST Parameter Fuzzing",
    "description": "Fuzzes POST request body parameters to discover hidden form fields.",
    "arguments": {
      "-X POST": "HTTP method",
      "-d": "POST data with FUZZ keyword",
      "-fs": "Filter size"
    },
    "expected_output": "password                [Status: 200, Size: 3421]\ntoken                   [Status: 200, Size: 3890]",
    "use_case": "Discover hidden POST parameters in login forms, APIs, or admin panels.",
    "prerequisites": [
      "Target URL with POST endpoint"
    ],
    "mitre_mapping": [
      "T1190"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "Unusual POST parameters in logs"
    ],
    "remediation": [
      "Validate all input parameters",
      "Use CSRF tokens"
    ],
    "common_mistakes": [
      "Not trying different content types (JSON, XML)"
    ],
    "alternatives": [
      "burp intruder",
      "wfuzz"
    ],
    "references": [
      "https://github.com/ffuf/ffuf"
    ],
    "tags": [
      "post",
      "parameter",
      "fuzzing",
      "form",
      "web"
    ]
