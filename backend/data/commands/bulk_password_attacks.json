    "name": "RDP Brute-Force",
    "description": "Brute-forces RDP login \u2014 use single thread to avoid lockout.",
    "arguments": {
      "-l": "Username",
      "-P": "Password list",
      "rdp://": "Protocol",
      "-t 1": "Single thread (avoid lockout)"
    },
    "expected_output": "[3389][rdp] host: 10.0.0.10 login: administrator password: P@ssw0rd",
