    "command": "unshadow /etc/passwd /etc/shadow > combined.txt && john combined.txt --wordlist=/usr/share/wordlists/rockyou.txt",
    "name": "Crack Linux Shadow Hashes",
    "description": "Combines passwd and shadow files, then cracks the password hashes.",
    "arguments": {
      "unshadow": "Combine passwd+shadow",
      "--wordlist": "Password list"
    },
