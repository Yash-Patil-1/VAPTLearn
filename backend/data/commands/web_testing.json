[
  {"id": "ffuf-dir-discovery", "tool": "ffuf", "category": "web_testing", "phase": 4, "os": ["linux", "windows", "macos"], "command": "ffuf -u http://<target>/FUZZ -w /usr/share/wordlists/dirb/common.txt -mc 200,301,302,403", "name": "Directory Discovery", "description": "Brute-force directories and files on a web server using a wordlist. FUZZ keyword is replaced with each word.", "arguments": {"-u": "Target URL with FUZZ keyword", "-w": "Wordlist path", "-mc": "Match HTTP status codes"}, "expected_output": "admin                   [Status: 301, Size: 312]\nlogin                   [Status: 200, Size: 1523]\nuploads                 [Status: 403, Size: 277]", "use_case": "Discover hidden directories, admin panels, backup files, and configuration files on web servers.", "prerequisites": ["Target web server URL", "Wordlist (SecLists recommended)"], "mitre_mapping": ["T1595"], "mitre_tactic": "Reconnaissance", "detections": ["WAF rate limiting alerts", "High volume of 404 responses in web logs", "Unusual User-Agent strings"], "remediation": ["Implement rate limiting", "Use WAF rules to block brute-force", "Remove unnecessary files/directories", "Implement proper access controls"], "common_mistakes": ["Not filtering by response size (-fs)", "Using too small a wordlist", "Not trying different extensions (-e .php,.html,.txt)"], "alternatives": ["gobuster dir", "feroxbuster", "dirsearch", "dirb"], "references": ["https://github.com/ffuf/ffuf"], "tags": ["directory", "brute-force", "web", "fuzzing", "content-discovery"]},
  {"id": "ffuf-vhost", "tool": "ffuf", "category": "web_testing", "phase": 4, "os": ["linux", "windows", "macos"], "command": "ffuf -u http://<target> -H 'Host: FUZZ.<domain>' -w subdomains.txt -fs <default_size>", "name": "Virtual Host Discovery", "description": "Discover virtual hosts by fuzzing the Host header. Useful when multiple sites are hosted on the same IP.", "arguments": {"-u": "Target URL", "-H": "Custom header with FUZZ keyword", "-w": "Subdomain wordlist", "-fs": "Filter by response size (exclude default page)"}, "expected_output": "dev                     [Status: 200, Size: 4521]\nstaging                 [Status: 200, Size: 3892]", "use_case": "Find hidden virtual hosts that aren't in DNS but respond to specific Host headers.", "prerequisites": ["Target IP", "Knowledge of default response size to filter"], "mitre_mapping": ["T1595"], "mitre_tactic": "Reconnaissance", "detections": ["Unusual Host header values in web logs", "High volume of requests with different Host headers"], "remediation": ["Configure web server to reject unknown Host headers", "Use default vhost that returns 404"], "common_mistakes": ["Not filtering default response size", "Forgetting to add domain suffix"], "alternatives": ["gobuster vhost", "wfuzz"], "references": ["https://github.com/ffuf/ffuf"], "tags": ["vhost", "virtual-host", "web", "fuzzing", "subdomain"]},
  {"id": "sqlmap-basic", "tool": "sqlmap", "category": "web_testing", "phase": 4, "os": ["linux", "windows", "macos"], "command": "sqlmap -u 'http://<target>/page?id=1' --batch --dbs", "name": "SQL Injection Detection & Database Enumeration", "description": "Automatically detects and exploits SQL injection vulnerabilities. --batch uses default answers, --dbs lists databases.", "arguments": {"-u": "Target URL with injectable parameter", "--batch": "Non-interactive mode (use defaults)", "--dbs": "Enumerate databases"}, "expected_output": "[*] available databases [3]:\n[*] information_schema\n[*] mysql\n[*] webapp_db", "use_case": "Test parameters for SQL injection and enumerate database contents if vulnerable.", "prerequisites": ["URL with potentially injectable parameter", "Understanding of SQL injection types"], "mitre_mapping": ["T1190"], "mitre_tactic": "Initial Access", "detections": ["WAF SQL injection signatures", "Database error messages in logs", "Unusual query patterns in DB audit logs"], "remediation": ["Use parameterized queries/prepared statements", "Implement input validation", "Deploy WAF with SQL injection rules", "Apply least privilege to database accounts"], "common_mistakes": ["Testing production databases without authorization", "Not trying POST parameters", "Ignoring blind SQL injection"], "alternatives": ["Manual testing with Burp Suite", "ghauri", "nosqlmap (for NoSQL)"], "references": ["https://sqlmap.org", "https://github.com/sqlmapproject/sqlmap"], "tags": ["sqli", "injection", "database", "web", "exploitation"]},
  {"id": "sqlmap-dump", "tool": "sqlmap", "category": "web_testing", "phase": 4, "os": ["linux", "windows", "macos"], "command": "sqlmap -u 'http://<target>/page?id=1' -D <database> -T <table> --dump", "name": "Database Table Dump", "description": "Dumps the contents of a specific table from a database after confirming SQL injection.", "arguments": {"-D": "Target database name", "-T": "Target table name", "--dump": "Dump table contents"}, "expected_output": "+----+----------+------------------+\n| id | username | password         |\n+----+----------+------------------+\n| 1  | admin    | 5f4dcc3b5aa765d6 |", "use_case": "Extract data from vulnerable databases to demonstrate impact of SQL injection.", "prerequisites": ["Confirmed SQL injection vulnerability", "Known database and table names"], "mitre_mapping": ["T1190", "T1005"], "mitre_tactic": "Collection", "detections": ["Large data transfers from database", "Unusual SELECT queries in DB logs", "Data exfiltration alerts"], "remediation": ["Fix the SQL injection vulnerability", "Encrypt sensitive data at rest", "Implement database activity monitoring"], "common_mistakes": ["Dumping entire databases (slow, noisy)", "Not checking for WAF bypass needed"], "alternatives": ["Manual UNION-based extraction", "Blind extraction with Burp Intruder"], "references": ["https://sqlmap.org/usage/"], "tags": ["sqli", "data-extraction", "database", "dump"]},
  {"id": "nuclei-scan", "tool": "nuclei", "category": "web_testing", "phase": 4, "os": ["linux", "windows", "macos"], "command": "nuclei -u http://<target> -t cves/ -severity critical,high", "name": "CVE Vulnerability Scan", "description": "Scans target for known CVEs using YAML-based templates. Fast, accurate, and community-maintained.", "arguments": {"-u": "Target URL", "-t cves/": "Use CVE templates directory", "-severity": "Filter by severity level"}, "expected_output": "[CVE-2021-44228] [critical] http://target:8080/\n[CVE-2023-22515] [critical] http://target/setup", "use_case": "Quickly check for known critical vulnerabilities across web applications.", "prerequisites": ["Target URL", "Updated nuclei templates (nuclei -update-templates)"], "mitre_mapping": ["T1190"], "mitre_tactic": "Initial Access", "detections": ["WAF alerts for exploit payloads", "IDS signatures matching CVE probes", "Application error logs"], "remediation": ["Patch identified CVEs immediately", "Implement virtual patching via WAF", "Remove vulnerable components"], "common_mistakes": ["Not updating templates before scanning", "Scanning without authorization", "Ignoring informational findings"], "alternatives": ["nmap --script vuln", "OpenVAS", "Nessus"], "references": ["https://github.com/projectdiscovery/nuclei", "https://github.com/projectdiscovery/nuclei-templates"], "tags": ["cve", "vulnerability", "templates", "automated", "web"]},
  {"id": "gobuster-dir", "tool": "gobuster", "category": "web_testing", "phase": 4, "os": ["linux", "windows", "macos"], "command": "gobuster dir -u http://<target> -w /usr/share/wordlists/dirbuster/directory-list-2.3-medium.txt -x php,html,txt -t 50", "name": "Directory Brute-Force with Extensions", "description": "Brute-force directories and files with specific extensions using multiple threads.", "arguments": {"dir": "Directory mode", "-u": "Target URL", "-w": "Wordlist", "-x": "File extensions to try", "-t": "Number of threads"}, "expected_output": "/admin                (Status: 301) [Size: 312]\n/login.php            (Status: 200) [Size: 1523]\n/config.txt           (Status: 200) [Size: 89]", "use_case": "Discover hidden files and directories, especially configuration files and admin panels.", "prerequisites": ["Target web server", "Appropriate wordlist"], "mitre_mapping": ["T1595"], "mitre_tactic": "Reconnaissance", "detections": ["High 404 rate in web logs", "WAF brute-force detection", "Rate limiting triggers"], "remediation": ["Remove unnecessary files", "Implement proper access controls", "Use WAF rate limiting"], "common_mistakes": ["Not trying multiple extensions", "Using too few threads (slow) or too many (blocked)"], "alternatives": ["ffuf (faster, more flexible)", "feroxbuster (recursive)", "dirsearch"], "references": ["https://github.com/OJ/gobuster"], "tags": ["directory", "brute-force", "web", "content-discovery", "extensions"]},
  {"id": "xsstrike-scan", "tool": "xsstrike", "category": "web_testing", "phase": 4, "os": ["linux"], "command": "xsstrike -u 'http://<target>/search?q=test' --crawl", "name": "XSS Vulnerability Scanner", "description": "Advanced XSS detection tool that uses fuzzing and context analysis to find cross-site scripting vulnerabilities.", "arguments": {"-u": "Target URL with parameter", "--crawl": "Crawl the target and test all found parameters"}, "expected_output": "[+] Reflections found: 2\n[+] Payload: <script>alert(1)</script>\n[+] Confidence: High", "use_case": "Detect reflected and stored XSS vulnerabilities in web applications.", "prerequisites": ["Target URL with user input reflection", "Understanding of XSS types"], "mitre_mapping": ["T1059.007"], "mitre_tactic": "Execution", "detections": ["WAF XSS signature detection", "CSP violation reports", "Input containing script tags in logs"], "remediation": ["Implement output encoding", "Use Content Security Policy (CSP)", "Validate and sanitize all input", "Use HTTPOnly and Secure cookie flags"], "common_mistakes": ["Only testing reflected XSS (missing stored)", "Not testing different contexts (attribute, JS, URL)"], "alternatives": ["Burp Suite Scanner", "dalfox", "manual testing"], "references": ["https://github.com/s0md3v/XSStrike"], "tags": ["xss", "cross-site-scripting", "web", "injection", "client-side"]},
  {"id": "nikto-scan", "tool": "nikto", "category": "web_testing", "phase": 4, "os": ["linux", "macos"], "command": "nikto -h http://<target> -o report.html -Format html", "name": "Web Server Vulnerability Scan", "description": "Comprehensive web server scanner checking for dangerous files, outdated software, and misconfigurations.", "arguments": {"-h": "Target host", "-o": "Output file", "-Format": "Output format (html, csv, txt)"}, "expected_output": "+ Server: Apache/2.4.52\n+ /admin/: Directory indexing found\n+ /phpinfo.php: PHP info file found\n+ OSVDB-3233: /icons/README: Apache default file found", "use_case": "Quick scan for common web server misconfigurations, default files, and known vulnerabilities.", "prerequisites": ["Target web server URL"], "mitre_mapping": ["T1595", "T1190"], "mitre_tactic": "Reconnaissance", "detections": ["WAF alerts for known scanner signatures", "High volume of 404/403 in logs", "Nikto User-Agent in logs"], "remediation": ["Remove default files and directories", "Disable directory listing", "Remove phpinfo.php", "Update web server software"], "common_mistakes": ["Running against CDN/WAF (gets blocked)", "Not combining with manual testing"], "alternatives": ["nuclei (more modern)", "whatweb (fingerprinting)", "wappalyzer"], "references": ["https://github.com/sullo/nikto"], "tags": ["web-server", "misconfiguration", "default-files", "automated", "scanner"]}
