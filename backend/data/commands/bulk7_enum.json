  {
    "id": "nmap-script-vnc",
    "tool": "nmap",
    "category": "enumeration",
    "phase": 2,
    "os": [
      "linux",
      "windows",
      "macos"
    ],
    "command": "nmap --script vnc-info,vnc-brute -p 5900 <target>",
    "name": "VNC Enumeration",
    "description": "Checks VNC authentication and attempts brute-force with common passwords.",
    "arguments": {
      "vnc-info": "Get VNC info",
      "vnc-brute": "Brute-force VNC"
    },
    "expected_output": "| vnc-info: Protocol version 3.8\n| vnc-brute: password - Valid credentials",
    "use_case": "Enumerate and brute-force VNC \u2014 often has weak or no authentication.",
    "prerequisites": [
      "VNC port 5900 open"
    ],
    "mitre_mapping": [
      "T1021"
    ],
    "mitre_tactic": "Lateral Movement",
    "detections": [
      "VNC connection attempts",
      "Brute-force patterns"
    ],
    "remediation": [
      "Strong VNC passwords",
      "Restrict VNC access",
      "Use SSH tunneling"
    ],
    "common_mistakes": [
      "VNC not running"
    ],
    "alternatives": [
      "hydra vnc",
      "vncviewer"
    ],
    "references": [
      "https://nmap.org/nsedoc/"
    ],
    "tags": [
      "vnc",
