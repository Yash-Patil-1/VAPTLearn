  {
    "id": "enum4linux-ng",
    "tool": "enum4linux-ng",
    "category": "enumeration",
    "phase": 2,
    "os": [
      "linux"
    ],
    "command": "enum4linux-ng -A <target>",
    "name": "Enum4linux-ng (Modern SMB Enum)",
    "description": "Modern rewrite of enum4linux \u2014 enumerates SMB shares, users, groups, policies.",
    "arguments": {
      "-A": "All enumeration"
    },
    "expected_output": "Users: admin, jsmith, svc_backup\nShares: C$, ADMIN$, Backups (READ)\nPassword Policy: min 8, lockout 5/30min",
    "use_case": "Comprehensive SMB/AD enumeration \u2014 first tool to run against Windows targets.",
    "prerequisites": [
      "SMB accessible (445)"
    ],
    "mitre_mapping": [
      "T1087"
    ],
    "mitre_tactic": "Discovery",
    "detections": [
      "SMB enumeration attempts",
      "Multiple RPC calls"
    ],
    "remediation": [
      "Restrict anonymous access",
      "Disable SMBv1"
    ],
    "common_mistakes": [
      "Anonymous access blocked"
    ],
    "alternatives": [
      "crackmapexec",
      "smbclient",
      "rpcclient"
    ],
    "references": [
      "https://github.com/cddmp/enum4linux-ng"
    ],
    "tags": [
      "enum4linux",
      "smb",
      "users",
      "shares",
      "enumeration"
    ]
